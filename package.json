{
  "name": "@appharbor/sdk",
  "version": "0.1.0",
  "description": "AppHarbor カートリッジ開発用 SDK の契約 (型 + 関数シグネチャ)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".":        "./src/index.ts",
    "./client": "./src/client.ts",
    "./types":  "./src/types.ts"
  },
  "files": [
    "src",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@supabase/supabase-js": "^2",
    "next":                  "^15 || ^16",
    "react":                 "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": { "optional": true },
    "next":                  { "optional": true },
    "react":                 { "optional": true }
  },
  "repository": {
    "type": "git",
    "url":  "https://github.com/Tori-Take/sdk.git"
  },
  "license": "MIT",
  "keywords": ["appharbor", "cartridge", "sdk", "supabase"],
  "publishConfig": {
    "access": "public"
  }
}
