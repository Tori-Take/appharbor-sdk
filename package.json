{
  "name": "@appharbor/sdk",
  "version": "0.2.0",
  "description": "AppHarbor カートリッジ開発用 SDK の契約 (型 + 関数シグネチャ)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src",
    "prompts",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "check-prompts": "node scripts/check-prompts.mjs"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2",
    "next": "^15 || ^16",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tori-Take/appharbor-sdk.git"
  },
  "license": "MIT",
  "keywords": [
    "appharbor",
    "cartridge",
    "sdk",
    "supabase"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "typescript": "^6.0.3"
  }
}
